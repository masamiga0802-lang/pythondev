   "source": [
    "#@title 九九のリストを作成する\n",
    "kuku = [[v * h for h in range(1, 10)] for v in range(1, 10)]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cdd06c1a",
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 九九の表を表示する\n",
    "for row in kuku:\n",
    "    for value in row:\n",
    "        print(f\"{value:3d}\", end=\"\")\n",
    "    print(\"\")"
   ]
  }
 ],
