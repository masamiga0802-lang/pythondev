   "source": [
    "total = 0\n",
    "count = 0\n",
    "\n",
    "while True:\n",
    "    score = int(input(\"点数を入力してください：\"))\n",
    "    \n",
    "    if score == -1:\n",
    "        break\n",
    "    \n",
    "    total += score\n",
    "    count += 1\n",
    "\n",
    "average = round(total / count, 1)\n",
    "print(f\"{count}人のテストの平均点は{average}点です\")"
