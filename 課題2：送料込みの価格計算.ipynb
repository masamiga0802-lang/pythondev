   "source": [
    "price = int(input(\"税抜価格を入力してください：\"))\n",
    "tax_price = round(price * 1.1)\n",
    "\n",
    "if tax_price >= 2000:\n",
    "    print(\"送料は無料です\")\n",
    "    total = tax_price\n",
    "else:\n",
    "    print(\"送料として350円かかります\")\n",
    "    total = tax_price + 350\n",
    "\n",
    "print(f\"送料込みの価格は{total}円です。\")"
   ]
  }
